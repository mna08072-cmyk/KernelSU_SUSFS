CONFIG_ENV=config.env

# Kernel
## Source
KERNEL_SOURCE=https://github.com/filiprrs/android_kernel_samsung_universal7880
KERNEL_SOURCE_BRANCH=lineage-20

## Defconfig
KERNEL_CONFIG=a7y17lte_defconfig
KERNEL_CONFIG_CUSTOM=false

## Compile
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false
EXTRA_CMDS=LD=ld.lld

# Clang
## Custom
USE_CUSTOM_CLANG=true
CUSTOM_CLANG_SOURCE=https://github.com/LineageOS/android_prebuilts_clang_kernel_linux-x86_clang-r416183b.git
CUSTOM_CLANG_BRANCH=lineage-20.0
CUSTOM_CMDS=CLANG_TRIPLE=aarch64-linux-gnu-

## AOSP
# CLANG_BRANCH=android15-tests-release
# CLANG_VERSION=r530567

# GCC
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=false
USE_CUSTOM_GCC_64=false
CUSTOM_GCC_64_BIN=aarch64-linux-android-
USE_CUSTOM_GCC_32=false

# SUSFS
ENABLE_SUSFS=true
SUSFS_SOURCE=https://gitlab.com/simonpunk/susfs4ksu
SUSFS_SOURCE_BRANCH=kernel-4.9
SUSFS_KERNELSU_MODE=1

# KernelSU flags
ENABLE_KERNELSU=true
ENABLE_KERNELSU_NONGKI_PATCH=false
KERNELSU_SETUP_SOURCE=https://raw.githubusercontent.com/KernelSU-Next/KernelSU-Next/next/kernel/setup.sh
KERNELSU_TAG=next-susfs
KERNELSU_TYPE=KernelSU-Next
# KSU_EXPECTED_SIZE=0x3e6
# KSU_EXPECTED_HASH=79e590...

# Configuration
DISABLE-LTO=false
DISABLE_CC_WERROR=false
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
APPLY_KSU_PATCH=false
REMOVE_UNUSED_PACKAGES=true

# AnyKernel3
USE_CUSTOM_ANYKERNEL3=false

# Ccache
ENABLE_CCACHE=true

# DTBO image
NEED_DTBO=false

# Build boot images
BUILD_BOOT_IMG=false
